# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://nordmfg.com

# Database
USE_SQLITE=true

# JWT Authentication
JWT_SECRET=change-this-to-a-random-string-in-production

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Uploaded-file handling
# Set to enable at-rest AES-256-GCM encryption of uploaded customer CAD files.
# Leave unset to store files unencrypted (default). Use a long random string.
# NORD_FILE_ENC_KEY=change-this-to-a-long-random-string
# Hours to keep uploaded files before the retention sweep deletes them (default 168 = 7 days).
# UPLOAD_RETENTION_HOURS=168

# Email (Resend or Postmark)
# EMAIL_API_KEY=re_...
# EMAIL_FROM=orders@nordmfg.com

# Shipping (EasyPost)
# EASYPOST_API_KEY=EZTKxxxxxxxxxx
